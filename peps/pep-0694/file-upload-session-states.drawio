<mxfile host="app.diagrams.net" type="device">
  <diagram id="file-upload-session-states" name="File Upload Session States">
    <mxGraphModel adaptiveColors="auto" dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1080" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="185" y="110" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="pending" value="pending" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="190" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="processing" value="processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="480" y="190" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="complete" value="complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="840" y="190" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="error" value="error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="480" y="440" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="canceled" value="canceled&#10;(terminal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=2;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="840" y="440" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="note" value="Cancel during processing is rejected with 409 (not a transition)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#999999;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="30" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_start_pending" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="start" target="pending">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pending_processing" value="completion deferred (202)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="pending" target="processing">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_processing_complete" value="deferred processing succeeds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="processing" target="complete">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pending_complete" value="completion immediate (201)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="pending" target="complete">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pending_error" value="completion fails synchronously" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pending" target="error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_pending_canceled" value="cancel (DELETE)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.6;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="pending" target="canceled">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="210" y="640" />
              <mxPoint x="915" y="640" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_pending_self" value="upload mechanism executes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="pending" target="pending">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="60" y="215" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_processing_error" value="deferred processing fails" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="processing" target="error">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_complete_canceled" value="delete file (DELETE)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="complete" target="canceled">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_error_canceled" value="delete file (DELETE)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="error" target="canceled">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
